{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jaywisdom.eth/schemas/ancient-wisdom-item-v0-1.json",
  "title": "ANCIENT_WISDOM_ITEM_SCHEMA_V0_1",
  "description": "Schema for Ancient Wisdom Collection items. Preserves fragments, attributions, interpretations, and civic/family wisdom without fake verification. Anchored by intent to jaywisdom.eth; does not assert L1 execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "collection",
    "item_id",
    "lane",
    "title",
    "fragment",
    "attribution_state",
    "truth_state",
    "claim_state",
    "render_green",
    "no_fake_green"
  ],
  "properties": {
    "collection": { "const": "ANCIENT_WISDOM_COLLECTION_V0_1" },
    "item_id": { "type": "string", "pattern": "^AWC-[0-9]{6}$" },
    "lane": {
      "type": "string",
      "enum": [
        "lane_aw_00_fragment_capture",
        "lane_aw_01_source_attribution",
        "lane_aw_02_translation_or_interpretation",
        "lane_aw_03_civic_application",
        "lane_aw_04_family_or_local_memory",
        "lane_aw_05_receipt_binding",
        "lane_aw_06_tombstone_or_correction",
        "lane_aw_07_surface_card"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "fragment": { "type": "string", "minLength": 1 },
    "attribution": { "type": ["string", "null"] },
    "attribution_state": {
      "type": "string",
      "enum": [
        "ATTRIBUTED_VERIFIED",
        "ATTRIBUTED_TRADITIONAL",
        "ATTRIBUTED_DISPUTED",
        "ATTRIBUTED_UNKNOWN",
        "ATTRIBUTED_PARAPHRASE"
      ]
    },
    "source_ref": { "type": ["string", "null"] },
    "translator_ref": { "type": ["string", "null"] },
    "interpretation_note": { "type": ["string", "null"] },
    "alms_entry_ref": { "type": ["string", "null"] },
    "almsl_line_ref": { "type": ["string", "null"] },
    "tombstone_ref": { "type": ["string", "null"] },
    "truth_state": { "type": "string", "enum": ["YELLOW", "GREEN", "RED"] },
    "claim_state": {
      "type": "string",
      "enum": ["UNKNOWN", "PRESERVED", "CANDIDATE", "UNVERIFIED", "PENDING", "PARTIAL", "VERIFIED", "REJECTED", "DEPRECATED", "SUPERSEDED"]
    },
    "render_green": { "type": "boolean" },
    "requires_human_approval": { "type": "boolean", "default": false },
    "human_approval_ref": { "type": ["string", "null"] },
    "no_fake_green": { "const": true },
    "identity_anchor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "immutable_seal": { "const": "jaywisdom.eth" },
        "mutable_engine": { "const": "jaywisdom.base.eth" },
        "l1_anchor_executed": { "type": "boolean" }
      }
    }
  }
}
