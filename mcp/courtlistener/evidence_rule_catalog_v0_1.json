{"rules":[{"class":"STRONG_CORROBORATION","contradiction":false,"description":"A provenance-bearing source exactly matches the candidate's material court fields.","promotion_eligible":true,"required_fields":["court.docket_number","court.date_filed","content.plain_text","source.event_hash","source.system"],"rule_id":"strong_corroboration_exact_match","weight":1.0},{"class":"WEAK_CORROBORATION","contradiction":false,"description":"Evidence matches at least one material field but does not satisfy the strong rule.","promotion_eligible":false,"required_fields":[],"rule_id":"weak_corroboration_partial_match","weight":0.4},{"class":"CONTRADICTION","contradiction":true,"description":"Evidence directly contradicts a material candidate field.","promotion_eligible":false,"required_fields":["content.plain_text"],"rule_id":"contradiction_direct","weight":-1.0},{"class":"PROVENANCE_GAP","contradiction":false,"description":"Evidence lacks source system or event-hash provenance.","promotion_eligible":false,"required_fields":["source.event_hash","source.system"],"rule_id":"provenance_gap_missing_source","weight":-0.5},{"class":"TEMPORAL_MISMATCH","contradiction":false,"description":"Evidence filing date differs from the candidate filing date.","promotion_eligible":false,"required_fields":["court.date_filed"],"rule_id":"temporal_mismatch_out_of_range","weight":-0.3}],"strong_threshold":1.0,"version":"0.1","weak_weight_promotion":false}